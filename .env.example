# ============================================================
# Academic Tools MCP — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── LLM (OpenAI-compatible, defaults to DeepSeek) ───────────
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── Zotero ────────────────────────────────────────────────────
# Remote API mode (default):
ZOTERO_LIBRARY_ID=your_library_id
ZOTERO_LIBRARY_TYPE=user
ZOTERO_API_KEY=your_zotero_api_key

# Local mode (Zotero desktop must be running):
# ZOTERO_LOCAL=true

# ── arXiv ─────────────────────────────────────────────────────
# Directory where downloaded PDFs are saved:
# - Relative path (recommended): resolved from MCP server current working directory
# - Absolute path: use full path like F:/apps_download/papers
ARXIV_STORAGE_PATH=papers

# ── OCR (MinerU) ──────────────────────────────────────────────
MINERU_API_BASE=https://mineru.net/api/v4
# MinerU API keys (add up to 5; unused slots can be left empty or omitted):
MINERU_API_KEY_1=your_token_here
MINERU_API_KEY_2=
MINERU_API_KEY_3=
MINERU_API_KEY_4=
MINERU_API_KEY_5=

# ── Paper processing ──────────────────────────────────────────
# Number of characters from full.md to send to LLM for metadata extraction:
METADATA_TEXT_LIMIT=6000

# MinerU proxy behavior
# false: do not use HTTP(S)_PROXY from system/VPN (recommended)
MINERU_TRUST_ENV=false
